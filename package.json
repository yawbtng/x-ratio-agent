{
  "name": "x-ratio-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous agent (Browserbase + Stagehand) that gets your X following down to a target by unfollowing non-mutuals you don't care about, on a schedule.",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "auth": "tsx src/cli.ts login",
    "spike0": "tsx src/cli.ts spike0",
    "scan": "tsx src/cli.ts scan",
    "score": "tsx src/cli.ts score",
    "report": "tsx src/cli.ts report",
    "cli": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "harvest": "tsx src/cli.ts harvest",
    "unfollow": "tsx src/cli.ts unfollow"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@browserbasehq/sdk": "^2.10.0",
    "@browserbasehq/stagehand": "^3.5.0",
    "dotenv": "^16.4.5",
    "zod": "^4.0.16"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "playwright-core": "^1.55.1"
  }
}
