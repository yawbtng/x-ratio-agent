# Copy to .env and fill in (or just run `pnpm setup`, which creates + checks this). .env is gitignored.

# Browserbase — https://www.browserbase.com/settings
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Your X handle WITHOUT the @ (e.g. yawbtng)
X_HANDLE=

# Anthropic key — used by `pnpm score` to rank how relevant each non-mutual is to you.
ANTHROPIC_API_KEY=

# Get your following down to this number (keeps mutuals + your allowlist + top-scoring others).
TARGET_FOLLOWING=750

# Residential proxy. OFF by default: X rate-limits per-account (not per-IP), so a proxy doesn't
# help and residential bandwidth is metered ($12/GB). Only set true if X starts IP-blocking you.
USE_PROXY=false

# Optional: override the Browserbase Context id at runtime. Normally lives in
# functions/config.local.ts (written by `pnpm auth` / `pnpm setup`), not here.
# X_CONTEXT_ID=
