# Copy to .env and fill in. .env is gitignored.

# Browserbase (Hobby plan) — https://www.browserbase.com/settings
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Your X handle WITHOUT the @ (e.g. yawbtng)
X_HANDLE=

# LLM key — only needed once we add relevance scoring (M2). Not used by Spike 0.
ANTHROPIC_API_KEY=

# Residential proxy: "true" routes the session through Browserbase proxies.
# Spike A tests with/without. Dev plan includes a proxy GB allowance — watch overage in the dashboard.
USE_PROXY=true
