# The `bb` CLI reads these to publish/invoke. Copy to `.env` and fill in (same values as the
# parent project's .env). The .env file is gitignored — never commit real keys.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Used by main.ts at runtime. Not secrets, but kept here so they're easy to rotate.
X_HANDLE=
X_CONTEXT_ID=8c6f0abe-73d1-4541-b796-eff6c30adbcd
