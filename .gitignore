node_modules/
dist/
.env

# ─── Personal data — NEVER commit (this is a public repo) ───────────────────────
# Your harvested follow graph, LLM keep/drop judgments, and the generated target list
# are personal. They stay on your disk (so your local grind keeps working) but are not
# tracked. Templates ship as *.example.* so others can see the shape.
# ignore data/ CONTENTS (not the dir itself) so we can keep .gitkeep tracked
data/*
functions/droplist.ts
functions/config.local.ts
interest-profile.md

# keep the empty data dir in the tree (example templates live at *.example.* and
# are not matched by the ignores above, so they stay tracked automatically)
!data/.gitkeep

# agent working notes (local)
tasks/
